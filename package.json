        "@angular/cli": "^21.2.19",
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@hug/eslint-config": "^26.0.0",
        "@schematics/angular": "^21.2.19",
        "@types/node": "^26.1.1",
        "@types/semver": "^7.7.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "rxjs": "7.8.2",
        "tsdown": "^0.22.5",
        "tsx": "^4.23.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.10"
